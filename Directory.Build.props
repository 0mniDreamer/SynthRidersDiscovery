<Project>
  <PropertyGroup>
    <!-- 
    ============================================================
    UPDATE THIS PATH TO YOUR SYNTH RIDERS INSTALLATION
    ============================================================
    
    Steam (default):
      C:\Program Files (x86)\Steam\steamapps\common\SynthRiders
    
    Oculus:
      C:\Program Files\Oculus\Software\Software\kluge-interactive-synth-riders
    
    Quest (with Link):
      Check your Oculus library path
    -->
    <SynthRidersPath>C:\Program Files (x86)\Steam\steamapps\common\SynthRiders</SynthRidersPath>
  </PropertyGroup>
</Project>
